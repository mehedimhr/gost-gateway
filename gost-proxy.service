[Unit]
Description=Gost Reverse Proxy Gateway (Multi-VPS TLS relay)
After=network-online.target tailscaled.service
Wants=network-online.target tailscaled.service
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStartPre=/usr/local/sbin/sync_fw.sh
ExecStartPre=/usr/local/sbin/gost-launch.sh --check
ExecStart=/usr/local/sbin/gost-launch.sh
Restart=always
RestartSec=5s
User=root
NoNewPrivileges=true
ProtectSystem=full
ReadWritePaths=/etc/gost

[Install]
WantedBy=multi-user.target
